# =============================================================================
# Web Wise Backend (Django) Environment Variables
# =============================================================================
# Copy this file to backend/.env and fill in real values.
# IMPORTANT: backend/.env is gitignored — never commit it.
# =============================================================================

# -----------------------------------------------------------------------------
# Django core
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=replace-me-with-a-50-char-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Data stores
# -----------------------------------------------------------------------------
# Postgres in production. Leave unset to fall back to SQLite for local dev.
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/webwise_db

# Redis powers Celery broker, result backend, and the cache.
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# CORS — Next.js frontend origin(s). Comma-separated.
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Public URL of THIS backend, used to generate absolute URLs for stored
# screenshots and uploaded media. No trailing slash.
# -----------------------------------------------------------------------------
BACKEND_PUBLIC_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# DataForSEO API — used by rankings, discovery, competitors, and the
# BrightLocal-adjacent SERP tools. Get credentials at https://dataforseo.com.
# -----------------------------------------------------------------------------
DATAFORSEO_LOGIN=your-dataforseo-login
DATAFORSEO_PASSWORD=your-dataforseo-password

# -----------------------------------------------------------------------------
# Optional — temp password used by `manage.py seed_initial_data` when creating
# new client/employee/test users. Falls back to a built-in default if unset.
# -----------------------------------------------------------------------------
# WEBWISE_SEED_PASSWORD=change-me-in-prod
