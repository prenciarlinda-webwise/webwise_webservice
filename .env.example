# =============================================================================
# Web Wise Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# IMPORTANT: Never commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# DASHBOARD API (Client Portal & Admin Dashboard)
# -----------------------------------------------------------------------------
# Django Backend API URL — read by src/lib/api.ts. Defaults to
# http://localhost:8000/api when unset, so dev usually works without it.
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# -----------------------------------------------------------------------------
# ANALYTICS & TRACKING (Client-Side - NEXT_PUBLIC_ prefix required)
# -----------------------------------------------------------------------------
# Note: GTM container ID is currently hardcoded in
# src/components/analytics/GoogleAnalytics.tsx — no env var required for
# tracking to work today. Add NEXT_PUBLIC_GTM_ID here once that file reads
# from env.

# Google Search Console Verification
# Get code from: https://search.google.com/search-console
# Navigate to: Settings > Ownership verification > HTML tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Bing Webmaster Tools Verification
# Get code from: https://www.bing.com/webmasters
# Navigate to: Settings > Site ownership > HTML Meta Tag
NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-code

# -----------------------------------------------------------------------------
# reCAPTCHA v3 (Spam Protection)
# Get keys from: https://www.google.com/recaptcha/admin
# Select reCAPTCHA v3 when creating
# -----------------------------------------------------------------------------

# Public site key (safe to expose - used in browser)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# SECRET KEY - SERVER-SIDE ONLY
# WARNING: This key must NEVER be exposed to the client/browser
# Keep this in .env.local only, never use NEXT_PUBLIC_ prefix
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# -----------------------------------------------------------------------------
# IndexNow API (Instant Indexing for Bing/Yandex)
# Generate a random alphanumeric string (8-128 characters)
# Example: openssl rand -hex 32
# -----------------------------------------------------------------------------

# SECRET KEY - SERVER-SIDE ONLY
# WARNING: This key must NEVER be exposed to the client/browser
# After setting, create a file at /public/{INDEXNOW_API_KEY}.txt containing the key
INDEXNOW_API_KEY=your-indexnow-api-key

# -----------------------------------------------------------------------------
# Google PageSpeed Insights API (Website Roast Tool)
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable the API at: https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com
# -----------------------------------------------------------------------------

# SECRET KEY - SERVER-SIDE ONLY
GOOGLE_PAGESPEED_API_KEY=your-pagespeed-api-key

# =============================================================================
# LAUNCH DAY CHECKLIST
# =============================================================================
# [ ] 1. Add all API keys above to your hosting dashboard (Vercel/Netlify)
# [ ] 2. Test /sitemap.xml renders correctly in browser
# [ ] 3. Submit sitemap to Google Search Console & Bing Webmaster Tools
# [ ] 4. Verify Google Business Profile is linked to website
# [ ] 5. Run PageSpeed Insights test (aim for 90+ scores)
# [ ] 6. Test contact form with reCAPTCHA enabled
# [ ] 7. Verify robots.txt at /robots.txt
# [ ] 8. Check all meta tags with https://metatags.io/
# [ ] 9. Test Open Graph tags with Facebook Sharing Debugger
# [ ] 10. Configure GTM tags and triggers for custom events
# =============================================================================